<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>University Authentication System</title>
    <style>
        body { font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; background: #f4f7f6; margin: 0; display: flex; justify-content: center; align-items: center; min-height: 100vh; color: #333; }
        
        .card { background: white; padding: 40px; border-radius: 8px; box-shadow: 0 4px 15px rgba(0,0,0,0.1); width: 100%; max-width: 350px; text-align: center; }
        .dashboard { max-width: 800px; width: 100%; padding: 30px; border-radius: 8px; background: white; box-shadow: 0 4px 15px rgba(0,0,0,0.1); margin: 20px; }
        
        h2 { margin-top: 0; margin-bottom: 20px; }
        .role-badge { display: inline-block; padding: 5px 15px; border-radius: 15px; color: white; font-weight: bold; font-size: 14px; margin-bottom: 20px; text-transform: uppercase; }
        
        input { width: 100%; padding: 12px; margin-bottom: 15px; border: 1px solid #ccc; border-radius: 4px; box-sizing: border-box; }
        
        .btn { padding: 10px 20px; border: none; border-radius: 4px; font-weight: bold; cursor: pointer; color: white; transition: 0.2s; }
        .btn-full { width: 100%; padding: 12px; }
        .btn-blue { background: #3498db; } .btn-blue:hover { background: #2980b9; }
        .btn-red { background: #e74c3c; } .btn-red:hover { background: #c0392b; }
        
        .error { color: #e74c3c; font-size: 14px; margin-bottom: 15px; display: none; }
        
        /* Screens */
        .screen { display: none; }
        .active-screen { display: block; }

        /* Dashboard Specific Styles */
        .grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 20px; margin-bottom: 20px; }
        .widget { padding: 20px; border-radius: 8px; text-align: left; color: white; }
        
        /* Role Colors */
        .theme-student { background: #3498db; } /* Blue */
        .theme-lecturer { background: #2ecc71; } /* Green */
        .theme-admin { background: #9b59b6; } /* Purple */
    </style>
</head>
<body>

    <div id="loginScreen" class="card screen active-screen">
        <h2 style="color: #2c3e50;">University Portal</h2>
        <p style="color: #7f8c8d; font-size: 14px; margin-bottom: 20px;">Role-Based Access Control System</p>
        
        <div id="loginError" class="error">Access Denied: Invalid Credentials</div>
        
        <input type="email" id="loginEmail" placeholder="Email Address">
        <input type="password" id="loginPassword" placeholder="Password">
        <button class="btn btn-blue btn-full" onclick="login()">Login to System</button>
        
        <div style="margin-top: 25px; text-align: left; font-size: 12px; background: #eee; padding: 10px; border-radius: 4px;">
            <strong>Test Accounts (Password is pass123 for all):</strong><br>
            student@uni.edu<br>
            lecturer@uni.edu<br>
            admin@uni.edu
        </div>
    </div>

    <div id="studentDashboard" class="dashboard screen">
        <div style="display: flex; justify-content: space-between; align-items: center; border-bottom: 2px solid #eee; padding-bottom: 15px; margin-bottom: 20px;">
            <h2 style="color: #2c3e50; margin: 0;">Student Portal</h2>
            <button class="btn btn-red" onclick="logout()">Logout</button>
        </div>
        <div class="role-badge theme-student">Role: Student Workspace</div>
        <h3 id="studentName">Welcome, User</h3>
        <div class="grid">
            <div class="widget theme-student">
                <h4>My Units</h4>
                <p>BIT4138 - Ethical Hacking<br>BIT3208 - Web Auth</p>
            </div>
            <div class="widget theme-student">
                <h4>Exam Results</h4>
                <p>Status: All cleared. Proceed to registration.</p>
            </div>
        </div>
        <p style="color: #777;">Access Restrictions applied. You cannot view staff or admin panels.</p>
    </div>

    <div id="lecturerDashboard" class="dashboard screen">
        <div style="display: flex; justify-content: space-between; align-items: center; border-bottom: 2px solid #eee; padding-bottom: 15px; margin-bottom: 20px;">
            <h2 style="color: #2c3e50; margin: 0;">Faculty Portal</h2>
            <button class="btn btn-red" onclick="logout()">Logout</button>
        </div>
        <div class="role-badge theme-lecturer">Role: Lecturer Workspace</div>
        <h3 id="lecturerName">Welcome, Faculty</h3>
        <div class="grid">
            <div class="widget theme-lecturer">
                <h4>Class Rosters</h4>
                <p>Manage your 3 active classes.</p>
            </div>
            <div class="widget theme-lecturer">
                <h4>Grade Entry</h4>
                <p>Upload mid-semester marks here.</p>
            </div>
        </div>
        <p style="color: #777;">Access Restrictions applied. You cannot modify system settings.</p>
    </div>

    <div id="adminDashboard" class="dashboard screen">
        <div style="display: flex; justify-content: space-between; align-items: center; border-bottom: 2px solid #eee; padding-bottom: 15px; margin-bottom: 20px;">
            <h2 style="color: #2c3e50; margin: 0;">System Control Center</h2>
            <button class="btn btn-red" onclick="logout()">Logout</button>
        </div>
        <div class="role-badge theme-admin">Role: Administrator Workspace</div>
        <h3 id="adminName">Welcome, Super Admin</h3>
        <div class="grid">
            <div class="widget theme-admin">
                <h4>User Management</h4>
                <p>Add/Remove Students and Faculty.</p>
            </div>
            <div class="widget theme-admin">
                <h4>System Logs</h4>
                <p>View all login attempts and security events.</p>
            </div>
        </div>
        <p style="color: #777;">Full System Access Granted. Proceed with caution.</p>
    </div>

    <script>
        // 1. Initialize Database with 3 specific roles
        if(!localStorage.getItem('multiUsers')) {
            const defaultUsers = [
                { name: 'Mirara Karioki', email: 'student@uni.edu', password: 'pass123', role: 'student' },
                { name: 'Dr. Smith', email: 'lecturer@uni.edu', password: 'pass123', role: 'lecturer' },
                { name: 'System Admin', email: 'admin@uni.edu', password: 'pass123', role: 'admin' }
            ];
            localStorage.setItem('multiUsers', JSON.stringify(defaultUsers));
        }

        // 2. Session Management Check on Load
        if(sessionStorage.getItem('activeRole')) {
            routeToDashboard(sessionStorage.getItem('activeRole'), sessionStorage.getItem('activeName'));
        }

        // 3. Authentication Logic
        function login() {
            const email = document.getElementById('loginEmail').value;
            const password = document.getElementById('loginPassword').value;
            
            const users = JSON.parse(localStorage.getItem('multiUsers'));
            const user = users.find(u => u.email === email && u.password === password);

            if(user) {
                // Set Secure Session
                sessionStorage.setItem('activeRole', user.role);
                sessionStorage.setItem('activeName', user.name);
                
                document.getElementById('loginEmail').value = '';
                document.getElementById('loginPassword').value = '';
                document.getElementById('loginError').style.display = 'none';
                
                routeToDashboard(user.role, user.name);
            } else {
                document.getElementById('loginError').style.display = 'block';
            }
        }

        // 4. Role-Based Routing & Access Restrictions
        function routeToDashboard(role, name) {
            // Hide all screens first
            document.querySelectorAll('.screen').forEach(s => s.classList.remove('active-screen'));
            
            // Unlock specific dashboard based on role
            if(role === 'student') {
                document.getElementById('studentName').innerText = `Welcome, ${name}`;
                document.getElementById('studentDashboard').classList.add('active-screen');
            } 
            else if (role === 'lecturer') {
                document.getElementById('lecturerName').innerText = `Welcome, ${name}`;
                document.getElementById('lecturerDashboard').classList.add('active-screen');
            } 
            else if (role === 'admin') {
                document.getElementById('adminName').innerText = `Welcome, ${name}`;
                document.getElementById('adminDashboard').classList.add('active-screen');
            }
        }

        // 5. Logout & Destroy Session
        function logout() {
            sessionStorage.clear();
            document.querySelectorAll('.screen').forEach(s => s.classList.remove('active-screen'));
            document.getElementById('loginScreen').classList.add('active-screen');
        }
    </script>
</body>
</html>
