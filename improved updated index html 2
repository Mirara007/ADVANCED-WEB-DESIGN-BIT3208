<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Secure Deadline Radar</title>
    <style>
        body { font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; background-color: #1e272e; margin: 0; display: flex; justify-content: center; align-items: center; min-height: 100vh; color: #333; }
        
        .container { width: 100%; max-width: 1000px; padding: 20px; }
        .card { background: white; padding: 30px; border-radius: 8px; box-shadow: 0 10px 30px rgba(0,0,0,0.5); }
        .auth-card { max-width: 380px; margin: 0 auto; text-align: center; }
        
        h2 { margin-top: 0; color: #2c3e50; margin-bottom: 5px; }
        .subtitle { color: #7f8c8d; font-size: 13px; margin-bottom: 20px; }
        
        /* Stats & UI */
        .stats-row { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 15px; margin-bottom: 25px; }
        .stat-box { padding: 15px; border-radius: 8px; color: white; text-align: center; font-weight: bold; }
        .stat-box.blue { background: #3498db; } .stat-box.orange { background: #e67e22; }
        .stat-box.red { background: #e74c3c; } .stat-box.green { background: #2ecc71; }
        .stat-value { font-size: 24px; margin-top: 5px; display: block; }
        
        /* Forms & Inputs */
        input, select { width: 100%; padding: 12px; margin-bottom: 15px; border: 1px solid #ccc; border-radius: 4px; box-sizing: border-box; background: #f9f9f9; }
        .form-row { display: flex; gap: 10px; margin-bottom: 15px; }
        
        /* Buttons */
        .btn { padding: 10px 15px; border: none; border-radius: 4px; cursor: pointer; color: white; font-weight: bold; transition: 0.2s; white-space: nowrap; }
        .btn-full { width: 100%; margin-bottom: 10px; padding: 12px; }
        .btn-blue { background: #3498db; } .btn-blue:hover { background: #2980b9; }
        .btn-green { background: #2ecc71; } .btn-green:hover { background: #27ae60; }
        .btn-red { background: #e74c3c; } .btn-red:hover { background: #c0392b; }
        .btn-orange { background: #f39c12; }
        
        /* Links & Checkboxes */
        .link { display: inline-block; margin-top: 10px; color: #34495e; cursor: pointer; text-decoration: underline; font-size: 13px; }
        .checkbox-container { display: flex; align-items: center; justify-content: flex-start; margin-bottom: 20px; font-size: 14px; color: #555; }
        .checkbox-container input { width: auto; margin: 0 10px 0 0; }
        
        /* Table */
        table { width: 100%; border-collapse: collapse; margin-top: 10px; }
        th, td { padding: 12px; text-align: left; border-bottom: 1px solid #eee; }
        th { background: #f8f9fa; color: #555; }
        .badge { padding: 4px 8px; border-radius: 12px; font-size: 11px; font-weight: bold; }
        .badge-pending { background: #fdf2e9; color: #d35400; }
        .badge-completed { background: #e8f8f5; color: #1abc9c; }
        .badge-overdue { background: #fadbd8; color: #c0392b; }

        /* Screens & Messages */
        .screen { display: none; }
        .active-screen { display: block; }
        .msg { font-size: 13px; margin-bottom: 15px; display: none; padding: 10px; border-radius: 4px; text-align: left;}
        .msg.success { background: #d5f5e3; color: #27ae60; border: 1px solid #2ecc71; }
        .msg.error { background: #fadbd8; color: #c0392b; border: 1px solid #e74c3c; }
    </style>
</head>
<body>

    <div id="loginScreen" class="card auth-card screen active-screen">
        <h2>Radar Gateway</h2>
        <div class="subtitle">Secure authentication required</div>
        
        <div id="loginMsg" class="msg error">Invalid credentials.</div>
        <div id="resetSuccessMsg" class="msg success">Password reset successfully! Please login.</div>
        
        <input type="email" id="loginEmail" placeholder="Email Address">
        <input type="password" id="loginPassword" placeholder="Password">
        
        <div class="checkbox-container">
            <input type="checkbox" id="rememberMe">
            <label for="rememberMe">Remember Me (Persistent Session)</label>
        </div>
        
        <button class="btn btn-blue btn-full" onclick="attemptLogin()">Login</button>
        <span class="link" onclick="switchScreen('resetScreen')">Forgot Password?</span>
    </div>

    <div id="tfaScreen" class="card auth-card screen">
        <h2>Security Check</h2>
        <div class="subtitle">2FA Verification required. Code sent to email.</div>
        
        <div style="background: #eee; padding: 10px; border-radius: 4px; margin-bottom: 15px; font-size: 12px;">*Test Code: <strong>123456</strong></div>
        <div id="tfaMsg" class="msg error">Invalid verification code.</div>
        
        <input type="text" id="tfaCode" placeholder="000000" maxlength="6" style="text-align: center; font-size: 20px; letter-spacing: 5px;">
        <button class="btn btn-blue btn-full" onclick="verify2FA()">Verify & Access</button>
        <span class="link" onclick="switchScreen('loginScreen')">Cancel</span>
    </div>

    <div id="resetScreen" class="card auth-card screen">
        <h2>Account Recovery</h2>
        <div class="subtitle">Verify your identity to reset password.</div>
        
        <div id="resetUI_1">
            <input type="email" id="resetEmail" placeholder="Enter registered email">
            <button class="btn btn-blue btn-full" onclick="simulateEmailVerification()">Send Recovery Code</button>
        </div>
        
        <div id="resetUI_2" style="display: none;">
            <div class="msg success" style="display: block;">Verification code sent! (Use: 0000)</div>
            <input type="text" id="resetCode" placeholder="Enter 4-digit code">
            <input type="password" id="newPassword" placeholder="Enter new password">
            <button class="btn btn-green btn-full" onclick="finalizePasswordReset()">Update Password</button>
        </div>
        
        <span class="link" onclick="switchScreen('loginScreen')">Back to Login</span>
    </div>

    <div id="dashboardScreen" class="container screen">
        <div class="card">
            <div style="display: flex; justify-content: space-between; align-items: center; border-bottom: 2px solid #eee; padding-bottom: 15px; margin-bottom: 20px;">
                <h2 style="margin: 0;">Deadline Radar</h2>
                <div>
                    <button class="btn btn-blue" onclick="switchScreen('profileScreen')">⚙ Profile</button>
                    <button class="btn btn-red" onclick="logout()">Logout</button>
                </div>
            </div>

            <div class="stats-row">
                <div class="stat-box blue">Total <span class="stat-value" id="statTotal">0</span></div>
                <div class="stat-box orange">Pending <span class="stat-value" id="statPending">0</span></div>
                <div class="stat-box red">Overdue <span class="stat-value" id="statOverdue">0</span></div>
                <div class="stat-box green">Completed <span class="stat-value" id="statCompleted">0</span></div>
            </div>

            <div style="background: #f8f9fa; padding: 15px; border-radius: 6px; margin-bottom: 20px;">
                <h4 style="margin-top: 0; color: #3498db;">+ Add Deadline</h4>
                <div class="form-row">
                    <input type="text" id="taskTitle" placeholder="Task Title" style="margin-bottom:0;">
                    <input type="text" id="taskCourse" placeholder="Course" style="margin-bottom:0;">
                    <input type="date" id="taskDate" style="margin-bottom:0;">
                    <button class="btn btn-blue" onclick="addTask()">Save</button>
                </div>
            </div>

            <table>
                <thead>
                    <tr>
                        <th>Task</th>
                        <th>Course</th>
                        <th>Due Date</th>
                        <th>Status</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody id="taskTableBody"></tbody>
            </table>
        </div>
    </div>

    <div id="profileScreen" class="container screen">
        <div class="card auth-card">
            <h2>Profile Settings</h2>
            <div class="subtitle">Manage your account details</div>
            
            <div id="profileMsg" class="msg success">Profile updated successfully!</div>
            
            <label style="font-size: 13px; font-weight: bold; color: #555; text-align: left; display: block;">Full Name</label>
            <input type="text" id="profileName">
            
            <label style="font-size: 13px; font-weight: bold; color: #555; text-align: left; display: block;">Email (Verified)</label>
            <input type="email" id="profileEmail" disabled style="background: #eee; cursor: not-allowed;">
            
            <label style="font-size: 13px; font-weight: bold; color: #555; text-align: left; display: block;">New Password</label>
            <input type="password" id="profilePassword" placeholder="Leave blank to keep current">
            
            <button class="btn btn-green btn-full" onclick="updateProfile()">Save Changes</button>
            <button class="btn btn-orange btn-full" onclick="switchScreen('dashboardScreen')">Back to Radar</button>
        </div>
    </div>

    <script>
        // --- DATA INITIALIZATION ---
        if(!localStorage.getItem('secureUsers')) {
            localStorage.setItem('secureUsers', JSON.stringify([{ name: 'Mirara Karioki', email: 'student@radar.com', password: 'pass123' }]));
        }
        if(!localStorage.getItem('secureTasks')) {
            localStorage.setItem('secureTasks', JSON.stringify([
                { owner: 'student@radar.com', title: 'Security Audit', course: 'BIT4138', date: '2026-05-19', status: 'pending' },
                { owner: 'student@radar.com', title: 'Old Assignment', course: 'BIT3208', date: '2025-01-01', status: 'pending' }
            ]));
        }

        let pendingAuthEmail = "";
        let activeUserEmail = "";

        // BONUS: Remember Me Check on Load
        if(localStorage.getItem('rememberedRadarUser')) {
            activeUserEmail = localStorage.getItem('rememberedRadarUser');
            switchScreen('dashboardScreen');
            loadTasks();
        }

        function switchScreen(screenId) {
            document.querySelectorAll('.screen').forEach(s => s.classList.remove('active-screen'));
            document.getElementById(screenId).classList.add('active-screen');
            document.querySelectorAll('.msg').forEach(m => m.style.display = 'none');
            
            if(screenId === 'profileScreen') populateProfile();
        }

        // --- AUTHENTICATION & 2FA ---
        function attemptLogin() {
            const email = document.getElementById('loginEmail').value;
            const password = document.getElementById('loginPassword').value;
            const users = JSON.parse(localStorage.getItem('secureUsers'));
            
            if(users.find(u => u.email === email && u.password === password)) {
                pendingAuthEmail = email; 
                switchScreen('tfaScreen'); // Trigger 2FA Bonus Feature
            } else {
                document.getElementById('loginMsg').style.display = 'block';
            }
        }

        function verify2FA() {
            if(document.getElementById('tfaCode').value === '123456') {
                activeUserEmail = pendingAuthEmail;
                if(document.getElementById('rememberMe').checked) {
                    localStorage.setItem('rememberedRadarUser', activeUserEmail);
                }
                switchScreen('dashboardScreen');
                loadTasks();
            } else {
                document.getElementById('tfaMsg').style.display = 'block';
            }
        }

        function logout() {
            localStorage.removeItem('rememberedRadarUser');
            activeUserEmail = "";
            document.getElementById('loginEmail').value = '';
            document.getElementById('loginPassword').value = '';
            document.getElementById('tfaCode').value = '';
            switchScreen('loginScreen');
        }

        // --- PASSWORD RESET BONUS ---
        function simulateEmailVerification() {
            if(!document.getElementById('resetEmail').value) return alert("Enter email.");
            document.getElementById('resetUI_1').style.display = 'none';
            document.getElementById('resetUI_2').style.display = 'block';
        }

        function finalizePasswordReset() {
            const code = document.getElementById('resetCode').value;
            const newPass = document.getElementById('newPassword').value;
            const email = document.getElementById('resetEmail').value;

            if(code === '0000' && newPass) {
                const users = JSON.parse(localStorage.getItem('secureUsers'));
                const index = users.findIndex(u => u.email === email);
                if(index !== -1) {
                    users[index].password = newPass;
                    localStorage.setItem('secureUsers', JSON.stringify(users));
                }
                document.getElementById('resetUI_1').style.display = 'block';
                document.getElementById('resetUI_2').style.display = 'none';
                switchScreen('loginScreen');
                document.getElementById('resetSuccessMsg').style.display = 'block';
            } else {
                alert("Invalid verification code.");
            }
        }

        // --- PROFILE MANAGEMENT BONUS ---
        function populateProfile() {
            const users = JSON.parse(localStorage.getItem('secureUsers'));
            const user = users.find(u => u.email === activeUserEmail);
            document.getElementById('profileName').value = user.name;
            document.getElementById('profileEmail').value = user.email;
            document.getElementById('profilePassword').value = "";
        }

        function updateProfile() {
            const newName = document.getElementById('profileName').value;
            const newPass = document.getElementById('profilePassword').value;
            const users = JSON.parse(localStorage.getItem('secureUsers'));
            const index = users.findIndex(u => u.email === activeUserEmail);
            
            users[index].name = newName;
            if(newPass) users[index].password = newPass;
            
            localStorage.setItem('secureUsers', JSON.stringify(users));
            document.getElementById('profileMsg').style.display = 'block';
        }

        // --- DEADLINE RADAR CRUD LOGIC ---
        function loadTasks() {
            const allTasks = JSON.parse(localStorage.getItem('secureTasks'));
            const myTasks = allTasks.filter(t => t.owner === activeUserEmail); // User-specific data
            
            const tbody = document.getElementById('taskTableBody');
            tbody.innerHTML = '';
            
            let stats = { total: myTasks.length, pending: 0, overdue: 0, completed: 0 };
            const today = new Date().toISOString().split('T')[0];

            myTasks.forEach((task, index) => {
                let badgeClass = 'badge-pending';
                let statusText = 'Pending';

                if (task.status === 'completed') {
                    stats.completed++; badgeClass = 'badge-completed'; statusText = 'Completed ✓';
                } else if (task.date < today) {
                    stats.overdue++; badgeClass = 'badge-overdue'; statusText = 'Overdue !';
                } else {
                    stats.pending++;
                }

                // We need the global index to modify the real array
                const globalIndex = allTasks.findIndex(t => t === task);

                tbody.innerHTML += `
                    <tr>
                        <td><strong>${task.title}</strong></td>
                        <td>${task.course}</td>
                        <td style="font-family: monospace;">${task.date}</td>
                        <td><span class="badge ${badgeClass}">${statusText}</span></td>
                        <td>
                            ${task.status !== 'completed' ? `<button class="btn btn-green" style="padding: 4px 8px; font-size: 11px;" onclick="markDone(${globalIndex})">✓</button>` : ''}
                            <button class="btn btn-red" style="padding: 4px 8px; font-size: 11px;" onclick="deleteTask(${globalIndex})">✕</button>
                        </td>
                    </tr>
                `;
            });

            document.getElementById('statTotal').innerText = stats.total;
            document.getElementById('statPending').innerText = stats.pending;
            document.getElementById('statOverdue').innerText = stats.overdue;
            document.getElementById('statCompleted').innerText = stats.completed;
        }

        function addTask() {
            const title = document.getElementById('taskTitle').value;
            const course = document.getElementById('taskCourse').value;
            const date = document.getElementById('taskDate').value;
            if(!title || !course || !date) return alert("Fill all fields.");

            const tasks = JSON.parse(localStorage.getItem('secureTasks'));
            tasks.push({ owner: activeUserEmail, title, course, date, status: 'pending' });
            localStorage.setItem('secureTasks', JSON.stringify(tasks));
            
            document.getElementById('taskTitle').value = '';
            document.getElementById('taskCourse').value = '';
            document.getElementById('taskDate').value = '';
            loadTasks();
        }

        function markDone(globalIndex) {
            const tasks = JSON.parse(localStorage.getItem('secureTasks'));
            tasks[globalIndex].status = 'completed';
            localStorage.setItem('secureTasks', JSON.stringify(tasks));
            loadTasks();
        }

        function deleteTask(globalIndex) {
            if(confirm("Remove this task?")) {
                const tasks = JSON.parse(localStorage.getItem('secureTasks'));
                tasks.splice(globalIndex, 1);
                localStorage.setItem('secureTasks', JSON.stringify(tasks));
                loadTasks();
            }
        }
    </script>
</body>
</html>
